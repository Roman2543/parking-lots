            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zone_name\": \"A\",\n  \"car_size\": \"small\",\n  \"parking_space\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/parking-lot/create",
              "host": ["{{baseUrl}}"],
              "path": ["parking-lot", "create"]
            }
          }
        },
